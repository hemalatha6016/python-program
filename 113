#You have a set S and one other set T. You need to update S by removing all elements that are also in T, and then print the sum of the remaining elements in S.

_ = int(input())
A =set(map(int, input().split()))
n_ops =int(input())
for _ in range(n_ops):
    operation=input().split()[0]
    other_set=set(map(int, input().split()))
    getattr(A,operation)(other_set)

print(sum(A))
